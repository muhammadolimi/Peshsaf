@model Peshsaf.Models.Product
@{
    var price = Model.GetCurrentPrice();
    var hasDiscount = price < Model.Price;
}
<div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden product-card">
    <img src="@(string.IsNullOrWhiteSpace(Model.ImageUrl) ? "https://placehold.co/600x400?text=No+Image" : Model.ImageUrl)" class="product-image" alt="@Model.Name" />
    <div class="card-body d-flex flex-column">
        <div class="small text-secondary mb-2">@Model.Category.Name</div>
        <h3 class="h6 fw-bold">@Model.Name</h3>
        <p class="text-secondary small flex-grow-1">@Model.Description</p>
        <div class="mb-3">
            @if (hasDiscount)
            {
                <span class="fw-bold">@price.ToString("0.##") c.</span>
                <span class="text-decoration-line-through text-secondary small ms-2">@Model.Price.ToString("0.##") c.</span>
            }
            else
            {
                <span class="fw-bold">@Model.Price.ToString("0.##") c.</span>
            }
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-outline-dark btn-sm flex-grow-1" asp-controller="Product" asp-action="Details" asp-route-id="@Model.Id">Подробнее</a>
            <form asp-controller="Cart" asp-action="Add" method="post" class="flex-grow-1">
                @Html.AntiForgeryToken()
                <input type="hidden" name="productId" value="@Model.Id" />
                <button class="btn btn-dark btn-sm w-100" type="submit">В корзину</button>
            </form>
            @if (Context.Session.GetInt32("UserId") != null)
            {
                <form asp-controller="Favorites" asp-action="Add" method="post" class="flex-grow-1">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@Model.Id" />
                    <button class="btn btn-outline-secondary btn-sm w-100" type="submit">В избранное</button>
                </form>
            }
        </div>
    </div>
</div>
