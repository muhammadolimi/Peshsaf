@model List<Peshsaf.Models.Promotion>
@{
    ViewData["Title"] = "Акции";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Акции</h1>
        <div class="text-secondary">Управление скидочными акциями</div>
    </div>
    <a class="btn btn-dark" asp-action="CreatePromotion">Добавить акцию</a>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Название</th>
                    <th>Скидка</th>
                    <th>Период</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var promo in Model)
                {
                    <tr>
                        <td>@promo.Id</td>
                        <td>@promo.Name</td>
                        <td>@promo.Discount %</td>
                        <td>@promo.StartDate.ToString("dd.MM.yyyy") - @promo.EndDate.ToString("dd.MM.yyyy")</td>
                        <td>
                            <div class="d-flex gap-2">
                                <a class="btn btn-outline-dark btn-sm" asp-action="EditPromotion" asp-route-id="@promo.Id">Изменить</a>
                                <form asp-action="DeletePromotion" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@promo.Id" />
                                    <button class="btn btn-outline-danger btn-sm" type="submit">Удалить</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>