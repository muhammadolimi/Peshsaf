@model Peshsaf.ViewModels.AdminPromotionFormViewModel
@{
    ViewData["Title"] = Model.Id.HasValue ? "Редактировать акцию" : "Добавить акцию";
    var actionName = Model.Id.HasValue ? "EditPromotion" : "CreatePromotion";
}
<div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 mx-auto" style="max-width: 650px;">
    <h1 class="h3 mb-4">@ViewData["Title"]</h1>
    <form asp-action="@actionName" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <div class="mb-3">
            <label asp-for="Name" class="form-label">Название</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Description" class="form-label">Описание</label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Description" class="text-danger small"></span>
        </div>
        <div class="row g-3">
            <div class="col-md-4">
                <label asp-for="Discount" class="form-label">Скидка (%)</label>
                <input asp-for="Discount" class="form-control" />
                <span asp-validation-for="Discount" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="StartDate" class="form-label">Дата начала</label>
                <input asp-for="StartDate" class="form-control" type="date" />
                <span asp-validation-for="StartDate" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="EndDate" class="form-label">Дата окончания</label>
                <input asp-for="EndDate" class="form-control" type="date" />
                <span asp-validation-for="EndDate" class="text-danger small"></span>
            </div>
        </div>
        <div class="d-flex gap-2 mt-4">
            <button class="btn btn-dark" type="submit">Сохранить</button>
            <a class="btn btn-outline-dark" asp-action="Promotions">Назад</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}