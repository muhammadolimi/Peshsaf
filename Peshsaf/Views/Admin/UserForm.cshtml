@model Peshsaf.ViewModels.AdminUserFormViewModel
@{
    ViewData["Title"] = Model.Id.HasValue ? "Редактировать пользователя" : "Добавить пользователя";
    var actionName = Model.Id.HasValue ? "EditUser" : "CreateUser";
}
<div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 mx-auto" style="max-width: 650px;">
    <h1 class="h3 mb-4">@ViewData["Title"]</h1>
    <form asp-action="@actionName" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Login" class="form-label">Логин</label>
                <input asp-for="Login" class="form-control" />
                <span asp-validation-for="Login" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Password" class="form-label">Пароль</label>
                <input asp-for="Password" class="form-control" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Email" class="form-label">Email</label>
                <input asp-for="Email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="RoleId" class="form-label">Роль</label>
                <select asp-for="RoleId" asp-items="Model.Roles" class="form-select"></select>
                <span asp-validation-for="RoleId" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Name" class="form-label">Имя</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="Phone" class="form-label">Телефон</label>
                <input asp-for="Phone" class="form-control" />
                <span asp-validation-for="Phone" class="text-danger small"></span>
            </div>
            <div class="col-md-12">
                <label asp-for="Address" class="form-label">Адрес</label>
                <input asp-for="Address" class="form-control" />
                <span asp-validation-for="Address" class="text-danger small"></span>
            </div>
            <div class="col-md-4">
                <label asp-for="BonusBalance" class="form-label">Бонусы</label>
                <input asp-for="BonusBalance" class="form-control" />
                <span asp-validation-for="BonusBalance" class="text-danger small"></span>
            </div>
        </div>
        <div class="d-flex gap-2 mt-4">
            <button class="btn btn-dark" type="submit">Сохранить</button>
            <a class="btn btn-outline-dark" asp-action="Users">Назад</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}