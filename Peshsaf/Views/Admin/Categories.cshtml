@model List<Peshsaf.Models.Category>
@{
    ViewData["Title"] = "Категории";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Категории</h1>
        <div class="text-secondary">Управление категориями товаров</div>
    </div>
    <a class="btn btn-dark" asp-action="CreateCategory">Добавить категорию</a>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Название</th>
                    <th>Родитель</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var category in Model)
                {
                    <tr>
                        <td>@category.Id</td>
                        <td>@category.Name</td>
                        <td>@category.Parent?.Name ?? "—"</td>
                        <td>
                            <div class="d-flex gap-2">
                                <a class="btn btn-outline-dark btn-sm" asp-action="EditCategory" asp-route-id="@category.Id">Изменить</a>
                                <form asp-action="DeleteCategory" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@category.Id" />
                                    <button class="btn btn-outline-danger btn-sm" type="submit">Удалить</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>