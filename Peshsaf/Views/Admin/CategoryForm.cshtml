@model Peshsaf.ViewModels.AdminCategoryFormViewModel
@{
    ViewData["Title"] = Model.Id.HasValue ? "Редактировать категорию" : "Добавить категорию";
    var actionName = Model.Id.HasValue ? "EditCategory" : "CreateCategory";
}
<div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 mx-auto" style="max-width: 650px;">
    <h1 class="h3 mb-4">@ViewData["Title"]</h1>
    <form asp-action="@actionName" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <div class="mb-3">
            <label asp-for="Name" class="form-label">Название</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger small"></span>
        </div>
        <div class="mb-3">
            <label asp-for="ParentId" class="form-label">Родительская категория</label>
            <select asp-for="ParentId" asp-items="Model.ParentOptions" class="form-select"></select>
            <span asp-validation-for="ParentId" class="text-danger small"></span>
        </div>
        <div class="d-flex gap-2 mt-4">
            <button class="btn btn-dark" type="submit">Сохранить</button>
            <a class="btn btn-outline-dark" asp-action="Categories">Назад</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}