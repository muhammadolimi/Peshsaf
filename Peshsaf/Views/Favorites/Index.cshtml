@model List<Peshsaf.Models.Favorite>
@{
    ViewData["Title"] = "Избранное";
}
<h1 class="h3 mb-4">Избранные товары</h1>

@if (!Model.Any())
{
    <div class="alert alert-light border">Вы ещё не добавили товары в избранное.</div>
}
else
{
    <div class="row g-4">
        @foreach (var fav in Model)
        {
            var product = fav.Product;
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden product-card">
                    <img src="@(string.IsNullOrWhiteSpace(product.ImageUrl) ? "https://placehold.co/600x400?text=No+Image" : product.ImageUrl)" class="product-image" alt="@product.Name" />
                    <div class="card-body d-flex flex-column">
                        <div class="small text-secondary mb-2">@product.Category?.Name</div>
                        <h3 class="h6 fw-bold">@product.Name</h3>
                        <p class="text-secondary small flex-grow-1">@product.Description</p>
                        <div class="mb-3">
                            @{
                                var price = product.GetCurrentPrice();
                                bool hasDiscount = price < product.Price;
                            }
                            @if (hasDiscount)
                            {
                                <span class="fw-bold">@price.ToString("0.##") c.</span>
                                <span class="text-decoration-line-through text-secondary small ms-2">@product.Price.ToString("0.##") c.</span>
                            }
                            else
                            {
                                <span class="fw-bold">@product.Price.ToString("0.##") c.</span>
                            }
                        </div>
                        <div class="d-flex gap-2">
                            <a class="btn btn-outline-dark btn-sm flex-grow-1" asp-controller="Product" asp-action="Details" asp-route-id="@product.Id">Подробнее</a>
                            <form asp-controller="Favorites" asp-action="Remove" method="post" class="flex-grow-1">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@product.Id" />
                                <button class="btn btn-outline-danger btn-sm w-100" type="submit">Убрать</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}