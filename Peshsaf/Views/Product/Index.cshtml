@model List<Peshsaf.Models.Product>

@{
    ViewData["Title"] = "Товары";

    var rootCategories = ViewBag.RootCategories as List<Peshsaf.Models.Category> ?? new();
    var childCategories = ViewBag.ChildCategories as List<Peshsaf.Models.Category> ?? new();
    var selectedCategory = ViewBag.SelectedCategory as Peshsaf.Models.Category;

    string search = ViewBag.Search as string ?? string.Empty;
    int? currentCategoryId = ViewBag.CategoryId as int?;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Каталог товаров</h1>
    <span class="text-secondary">Всего: @Model.Count</span>
</div>

<form method="get" class="row g-2 mb-4">
    <div class="col-md-6">
        <input class="form-control"
               type="text"
               name="search"
               value="@search"
               placeholder="Поиск по названию или описанию" />
    </div>

    <div class="col-md-4">
        <select class="form-select" name="categoryId">
            <option value="">Все категории</option>
            @foreach (var category in rootCategories)
            {
                if (currentCategoryId == category.Id)
                {
                    <option value="@category.Id" selected>@category.Name</option>
                }
                else
                {
                    <option value="@category.Id">@category.Name</option>
                }
            }
        </select>
    </div>

    <div class="col-md-2 d-grid">
        <button class="btn btn-dark" type="submit">Найти</button>
    </div>
</form>

@if (selectedCategory != null)
{
    <div class="mb-4">
        <div class="d-flex flex-wrap align-items-center gap-2 mb-2">
            <span class="text-secondary">Текущая категория:</span>
            <span class="fw-semibold">@selectedCategory.Name</span>
        </div>

        @if (childCategories.Any())
        {
            <h5 class="mb-3">Подкатегории</h5>
            <div class="d-flex flex-wrap gap-2">
                @foreach (var category in childCategories)
                {
                    <a asp-controller="Product"
                           asp-action="Index"
                           asp-route-categoryId="@category.Id"
                           asp-route-search="@search"
                           class="btn btn-outline-dark">
                        @category.Name
                    </a>
                }
            </div>
        }
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-light border">
        По этому запросу товары не найдены.
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var product in Model)
        {
            <div class="col-md-6 col-lg-4">
                <partial name="~/Views/Shared/_ProductCard.cshtml" model="product" />
            </div>
        }
    </div>
}