@{
    var userName = Context.Session.GetString("UserName");
    var userRole = Context.Session.GetString("UserRole");
}
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Peshsaf</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="border-bottom bg-white sticky-top">
        <nav class="navbar navbar-expand-lg container py-3">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">Peshsaf</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Главная</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Product" asp-action="Index">Товары</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Cart" asp-action="Index">Корзина</a></li>
                    @if (userRole == "Admin")
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Admin" asp-action="Index">Админ панель</a></li>
                    }
                </ul>
                <div class="d-flex gap-2 align-items-center">
                    @if (!string.IsNullOrWhiteSpace(userName))
                    {
                        <span class="text-secondary small">@userName (@userRole)</span>
                        <a class="btn btn-outline-dark btn-sm" asp-controller="Account" asp-action="Logout">Выход</a>
                    }
                    else
                    {
                        <a class="btn btn-outline-dark btn-sm" asp-controller="Account" asp-action="Login">Вход</a>
                        <a class="btn btn-dark btn-sm" asp-controller="Account" asp-action="Register">Регистрация</a>
                    }
                </div>
            </div>
        </nav>
    </header>

    <main class="container py-4">
        @if (TempData["AdminError"] != null)
        {
            <div class="alert alert-warning">@TempData["AdminError"]</div>
        }
        @if (TempData["AdminSuccess"] != null)
        {
            <div class="alert alert-success">@TempData["AdminSuccess"]</div>
        }
        @RenderBody()
    </main>

    <footer class="border-top py-4 mt-4 text-center text-muted small">
        Peshsaf • магазин электронной техники
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
