@model SomonStore.ViewModels.AdminProductFormViewModel
@{
    ViewData["Title"] = Model.Id.HasValue ? "Редактировать товар" : "Добавить товар";
    var actionName = Model.Id.HasValue ? "EditProduct" : "CreateProduct";
}
<div class="card border-0 shadow-sm rounded-4 p-4 p-md-5 mx-auto" style="max-width: 850px;">
    <h1 class="h3 mb-4">@ViewData["Title"]</h1>
    <form asp-action="@actionName" method="post">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <div class="row g-3">
            <div class="col-md-6">
                <label asp-for="Name" class="form-label"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Price" class="form-label"></label>
                <input asp-for="Price" class="form-control" />
                <span asp-validation-for="Price" class="text-danger small"></span>
            </div>
            <div class="col-md-3">
                <label asp-for="Quantity" class="form-label"></label>
                <input asp-for="Quantity" class="form-control" />
                <span asp-validation-for="Quantity" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="CategoryId" class="form-label">Категория</label>
                <select asp-for="CategoryId" asp-items="Model.Categories" class="form-select"></select>
                <span asp-validation-for="CategoryId" class="text-danger small"></span>
            </div>
            <div class="col-md-6">
                <label asp-for="ImageUrl" class="form-label"></label>
                <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
            </div>
            <div class="col-12">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="5"></textarea>
                <span asp-validation-for="Description" class="text-danger small"></span>
            </div>
        </div>
        <div class="d-flex gap-2 mt-4">
            <button class="btn btn-dark" type="submit">Сохранить</button>
            <a class="btn btn-outline-dark" asp-action="Index">Назад</a>
        </div>
    </form>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
