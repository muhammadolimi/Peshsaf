@model List<SomonStore.Models.Product>
@{
    ViewData["Title"] = "Админ панель";
}
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="h3 mb-1">Админ панель</h1>
        <div class="text-secondary">Управление товарами магазина</div>
    </div>
    <a class="btn btn-dark" asp-action="CreateProduct">Добавить товар</a>
</div>

<div class="card border-0 shadow-sm rounded-4">
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Товар</th>
                    <th>Категория</th>
                    <th>Цена</th>
                    <th>Остаток</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var product in Model)
                {
                    <tr>
                        <td>@product.Id</td>
                        <td>
                            <div class="d-flex gap-3 align-items-center">
                                <img src="@(string.IsNullOrWhiteSpace(product.ImageUrl) ? "https://placehold.co/120x80?text=No+Image" : product.ImageUrl)" class="cart-thumb" alt="@product.Name" />
                                <div>
                                    <div class="fw-semibold">@product.Name</div>
                                    <div class="small text-secondary">@product.Description</div>
                                </div>
                            </div>
                        </td>
                        <td>@product.Category.Name</td>
                        <td>@product.Price.ToString("0.##") c.</td>
                        <td>@product.Quantity</td>
                        <td>
                            <div class="d-flex gap-2">
                                <a class="btn btn-outline-dark btn-sm" asp-action="EditProduct" asp-route-id="@product.Id">Изменить</a>
                                <form asp-action="DeleteProduct" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@product.Id" />
                                    <button class="btn btn-outline-danger btn-sm" type="submit">Удалить</button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
