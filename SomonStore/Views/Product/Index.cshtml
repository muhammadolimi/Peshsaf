@model List<SomonStore.Models.Product>
@{
    ViewData["Title"] = "Товары";
    var categories = ViewBag.Categories as List<SomonStore.Models.Category> ?? new();
    string search = ViewBag.Search as string ?? string.Empty;
    int? currentCategoryId = ViewBag.CategoryId as int?;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Каталог товаров</h1>
    <span class="text-secondary">Всего: @Model.Count</span>
</div>

<form method="get" class="row g-2 mb-4">
    <div class="col-md-6">
        <input class="form-control" type="text" name="search" value="@search" placeholder="Поиск по названию или описанию" />
    </div>
    <div class="col-md-4">
        <select class="form-select" name="categoryId">
            <option value="">Все категории</option>
            @foreach (var category in categories)
            {
                if (currentCategoryId == category.Id)
                {
                    <option value="@category.Id" selected>@category.Name</option>
                }
                else
                {
                    <option value="@category.Id">@category.Name</option>
                }
            }
        </select>
    </div>
    <div class="col-md-2 d-grid">
        <button class="btn btn-dark" type="submit">Найти</button>
    </div>
</form>

@if (!Model.Any())
{
    <div class="alert alert-light border">По этому запросу товары не найдены.</div>
}
else
{
    <div class="row g-4">
        @foreach (var product in Model)
        {
            <div class="col-md-6 col-lg-4">
                <partial name="~/Views/Shared/_ProductCard.cshtml" model="product" />
            </div>
        }
    </div>
}
