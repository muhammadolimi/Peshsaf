@model SomonStore.Models.Cart
@{
    ViewData["Title"] = "Оформление заказа";
    decimal total = Model.Items.Sum(i => i.Product.GetCurrentPrice() * i.Quantity);
}
<h1 class="h3 mb-4">Оформление заказа</h1>
<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm rounded-4 p-4">
            <h2 class="h5 mb-3">Состав заказа</h2>
            <div class="vstack gap-3">
                @foreach (var item in Model.Items)
                {
                    <div class="d-flex justify-content-between border-bottom pb-3">
                        <div>
                            <div class="fw-semibold">@item.Product.Name</div>
                            <div class="small text-secondary">Количество: @item.Quantity</div>
                        </div>
                        <div>@((item.Product.GetCurrentPrice() * item.Quantity).ToString("0.##")) c.</div>
                    </div>
                }
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm rounded-4 p-4">
            <h2 class="h5 mb-3">Подтверждение</h2>
            <div class="d-flex justify-content-between mb-4"><span>Итого</span><b>@total.ToString("0.##") c.</b></div>
            <form asp-action="Create" method="post">
                @Html.AntiForgeryToken()
                <button class="btn btn-dark w-100" type="submit">Подтвердить заказ</button>
            </form>
        </div>
    </div>
</div>
